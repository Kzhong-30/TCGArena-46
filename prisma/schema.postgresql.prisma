generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  LOFT
  VILLA
  TOWNHOUSE
  DORMITORY
  SHARED
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  RENTED
  SOLD
}

enum RentPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
  RESCHEDULED
  NO_SHOW
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum ComplaintStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
  ESCALATED
}

enum ComplaintType {
  PROPERTY
  USER
  BOOKING
  PAYMENT
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Orientation {
  NORTH
  SOUTH
  EAST
  WEST
  NORTHEAST
  SOUTHEAST
  NORTHWEST
  SOUTHWEST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          UserRole  @default(TENANT)
  isActive      Boolean   @default(true)
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  bookingsAsLandlord Booking[] @relation("LandlordBookings")
  bookingsAsTenant Booking[] @relation("TenantBookings")
  reviewsAsTenant Review[] @relation("TenantReviews")
  favorites     Favorite[]
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  complaintsFiled Complaint[] @relation("FiledComplaints")
  complaintsReceived Complaint[] @relation("ReceivedComplaints")
  complaintsHandled Complaint[] @relation("HandledComplaints")
  accounts      Account[]
  sessions      Session[]

  @@index([role])
  @@index([email])
}

model Property {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  price         Decimal   @db.Decimal(12, 2)
  rentPeriod    RentPeriod @default(MONTHLY)
  deposit       Decimal?  @db.Decimal(12, 2)
  area          Decimal   @db.Decimal(10, 2)
  bedrooms      Int
  bathrooms     Int
  floor         Int?
  totalFloors   Int?
  orientation   Orientation?
  type          PropertyType
  furnished     Boolean   @default(false)
  hasParking    Boolean   @default(false)
  hasElevator   Boolean   @default(false)
  hasBalcony    Boolean   @default(false)
  hasGarden     Boolean   @default(false)
  hasPool       Boolean   @default(false)
  hasGym        Boolean   @default(false)
  petsAllowed   Boolean   @default(false)
  smokingAllowed Boolean  @default(false)
  amenities     Json?
  address       String
  city          String
  district      String
  province      String
  zipCode       String?
  latitude      Decimal?  @db.Decimal(10, 8)
  longitude     Decimal?  @db.Decimal(11, 8)
  images        Json
  videoUrl      String?
  virtualTourUrl String?
  status        PropertyStatus @default(PENDING)
  listingStatus ListingStatus @default(ACTIVE)
  isFeatured    Boolean   @default(false)
  availableFrom DateTime?
  minimumStay   Int?      @default(1)
  maximumStay   Int?
  landlordId    String
  landlord      User      @relation(fields: [landlordId], references: [id])
  bookings      Booking[]
  reviews       Review[]
  messages      Message[]
  complaints    Complaint[]
  favorites     Favorite[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([landlordId])
  @@index([city, district])
  @@index([price])
  @@index([status, listingStatus])
  @@index([type])
  @@index([bedrooms, bathrooms])
}

model Booking {
  id            String    @id @default(cuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        User      @relation("TenantBookings", fields: [tenantId], references: [id])
  landlordId    String
  landlord      User      @relation("LandlordBookings", fields: [landlordId], references: [id])
  preferredDate DateTime
  preferredTime String
  alternateDate DateTime?
  alternateTime String?
  message       String?   @db.Text
  numberOfPeople Int?
  status        BookingStatus @default(PENDING)
  rejectionReason String?  @db.Text
  rescheduleNote String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([landlordId])
  @@index([propertyId])
  @@index([status])
  @@index([preferredDate])
}

model Message {
  id            String    @id @default(cuid())
  senderId      String
  sender        User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId    String
  receiver      User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  content       String    @db.Text
  status        MessageStatus @default(SENT)
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([propertyId])
  @@index([isRead])
  @@index([createdAt])
}

model Review {
  id            String    @id @default(cuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        User      @relation("TenantReviews", fields: [tenantId], references: [id])
  bookingId     String?
  rating        Int
  cleanliness   Int?
  location      Int?
  communication Int?
  value         Int?
  comment       String?   @db.Text
  reply         String?   @db.Text
  replyAt       DateTime?
  createdAt     DateTime  @default(now())

  @@unique([propertyId, tenantId])
  @@index([propertyId])
  @@index([tenantId])
}

model Complaint {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  type          ComplaintType
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  complainantId String
  complainant   User      @relation("FiledComplaints", fields: [complainantId], references: [id])
  respondentId  String?
  respondent    User?     @relation("ReceivedComplaints", fields: [respondentId], references: [id])
  handlerId     String?
  handler       User?     @relation("HandledComplaints", fields: [handlerId], references: [id])
  status        ComplaintStatus @default(OPEN)
  priority      Priority?
  resolution    String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([complainantId])
  @@index([respondentId])
  @@index([handlerId])
  @@index([type, status])
}

model Favorite {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
